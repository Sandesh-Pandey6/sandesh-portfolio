# Contact form → sandesh.pandey00112@gmail.com (see src/data/site.ts)
# 1. Sign up at https://resend.com with THAT Gmail address
# 2. API Keys → Create API Key
# 3. Copy into .env.local as RESEND_API_KEY=re_...
# 4. Restart: npm run dev

RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: override inbox (defaults to SITE_EMAIL in src/data/site.ts)
# CONTACT_TO_EMAIL=sandesh.pandey00112@gmail.com

# Required for verification codes to visitors: verify a domain at Resend, then:
# RESEND_FROM=Portfolio <hello@yourdomain.com>

# Optional: secret for contact verification tokens (defaults to ADMIN_PASSWORD)
# CONTACT_VERIFY_SECRET=

# Portfolio admin — edit projects at http://localhost:3000/admin
ADMIN_PASSWORD=choose-a-strong-password

# Optional: extra session secret (defaults to ADMIN_PASSWORD)
# ADMIN_SECRET=

# Optional on Vercel: Blob store token so admin saves work in production
# BLOB_READ_WRITE_TOKEN=

# Cloudinary — upload videos from /admin (https://cloudinary.com free account)
# Dashboard → Settings → API Keys (put real values in .env.local only, not here)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Recommended if you see "missing permissions (create)" — fixes browser uploads:
# Cloudinary → Upload presets → Add preset → Signing: Unsigned → Folder: portfolio
CLOUDINARY_UPLOAD_PRESET=portfolio_unsigned

# Optional project demos (env overrides; can also set in /admin)
# Live deploy (ShopNext, etc.):
# NEXT_PUBLIC_LIVE_SHOPNEXT=https://your-app.vercel.app
# Unlisted YouTube or /public/projects/*.mp4 (TaskFlow API, DataPulse, etc.):
# NEXT_PUBLIC_DEMO_TASKFLOW_API=https://youtu.be/xxxxxxxxxxx
# NEXT_PUBLIC_DEMO_DATAPULSE=https://youtu.be/xxxxxxxxxxx
